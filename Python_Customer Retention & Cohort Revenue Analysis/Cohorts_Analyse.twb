      <aliases enabled='yes' />
      <column datatype='real' default-format='p0.00%' name='[Calculation1]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([revenue]) / TOTAL(SUM([revenue]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Total Customers' datatype='integer' name='[Calculation_602356497548775424]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([customer_id])' />
      </column>
      <column caption='Total Orders' datatype='integer' name='[Calculation_602356497554206721]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(invoice)' />
      </column>
      <column caption='Retention Rate' datatype='real' name='[Calculation_602356497556598786]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([customer_id])&#13;&#10;/&#13;&#10;WINDOW_MAX(COUNTD([customer_id]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Cohort Month Date' datatype='date' name='[Calculation_602356497573720071]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATE([cohort_month] + &quot;-01&quot;)' />
      </column>
      <column aggregation='Sum' caption='Cohort Year' datatype='integer' name='[Calculation_602356497574227976]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='YEAR([Calculation_602356497573720071])' />
      </column>
      <column caption='ARPU' datatype='real' name='[Calculation_940126469924839424]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(revenue) / COUNTD(customer_id)' />
      </column>
      <column caption='Retention Month 1' datatype='real' name='[Calculation_940126469925445633]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF cohort_index = 1 THEN customer_id END)&#13;&#10;/ &#13;&#10;COUNTD(IF cohort_index = 0 THEN customer_id END)' />
      </column>
      <column caption='Repeat Purchase Rate' datatype='real' name='[Calculation_940126469926445058]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(&#13;&#10;IF { FIXED customer_id : COUNTD(invoice) } &gt; 1&#13;&#10;THEN customer_id&#13;&#10;END&#13;&#10;)&#13;&#10;/ COUNTD(customer_id)' />
      </column>
